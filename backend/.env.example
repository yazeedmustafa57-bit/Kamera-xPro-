# SmartCam Pro - Cloud Server Konfiguration

# Datenbank (PostgreSQL fuer Cloud, SQLite fuer lokale Entwicklung)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smartcampro

# Sicherheit (AENDERN in Produktion!)
SECRET_KEY=dein-super-geheimer-schluessel-hier-aendern
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS (fuer deine Domain)
CORS_ORIGINS=["https://smartcampro.de","https://app.smartcampro.de","*"]

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine-email@gmail.com
SMTP_PASSWORD=dein-app-passwort
ALARM_EMAIL=deine-email@gmail.com

# Speicher
RECORDING_DIR=static/recordings
SCREENSHOT_DIR=static/screenshots
MAX_RECORDING_DAYS=30
