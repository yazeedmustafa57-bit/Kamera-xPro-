<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1e293b"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#ffffff"
            android:backgroundTint="#475569"
            android:textSize="18sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️ Einstellungen"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- BEWEGUNSERKENNUNG -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚶 Bewegungserkennung"
                android:textColor="#f59e0b"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Empfindlichkeit"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <SeekBar
                    android:id="@+id/sensitivitySeek"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50" />
                <TextView
                    android:id="@+id/sensitivityLabel"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="50%"
                    android:textColor="#f59e0b"
                    android:textSize="12sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- ZEITPLAN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏰ Zeitplan"
                android:textColor="#8b5cf6"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nachtmodus aktiv (18-06 Uhr)"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <Switch
                    android:id="@+id/nightModeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto-Alarm nachts"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <Switch
                    android:id="@+id/autoAlarmNightSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto-Taschenlampe nachts"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <Switch
                    android:id="@+id/autoFlashNightSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <!-- ALARM -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚨 Alarm"
                android:textColor="#ef4444"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sirene bei Bewegung"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <Switch
                    android:id="@+id/alarmOnMotionSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lautstärke"
                    android:textColor="#ffffff"
                    android:textSize="13sp" />
                <SeekBar
                    android:id="@+id/volumeSeek"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="70" />
                <TextView
                    android:id="@+id/volumeLabel"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="70%"
                    android:textColor="#ef4444"
                    android:textSize="12sp"
                    android:gravity="end" />
            </LinearLayout>

            <!-- BENUTZER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👤 Benutzerverwaltung"
                android:textColor="#22c55e"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/newUsername"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Benutzername"
                    android:textColor="#ffffff"
                    android:textColorHint="#64748b"
                    android:background="#1e293b"
                    android:paddingHorizontal="12dp"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />
                <EditText
                    android:id="@+id/newPassword"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="Passwort"
                    android:inputType="textPassword"
                    android:textColor="#ffffff"
                    android:textColorHint="#64748b"
                    android:background="#1e293b"
                    android:paddingHorizontal="12dp"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/addUserButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textColor="#ffffff"
                    android:backgroundTint="#22c55e"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/userListText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Angemeldet: admin"
                android:textColor="#94a3b8"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- SPEICHER -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾 Speicherverwaltung"
                android:textColor="#06b6d4"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/storageInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lade..."
                android:textColor="#94a3b8"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">
                <Button
                    android:id="@+id/clearScreenshotsBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="📸 Screenshots"
                    android:textColor="#ffffff"
                    android:backgroundTint="#f59e0b"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />
                <Button
                    android:id="@+id/clearRecordingsBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🎬 Aufnahmen"
                    android:textColor="#ffffff"
                    android:backgroundTint="#f59e0b"
                    android:textSize="11sp"
                    android:layout_marginEnd="6dp" />
                <Button
                    android:id="@+id/clearAllDataBtn"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🗑️ Alles"
                    android:textColor="#ffffff"
                    android:backgroundTint="#ef4444"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
