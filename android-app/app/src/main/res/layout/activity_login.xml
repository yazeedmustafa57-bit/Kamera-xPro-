<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a"
    android:gravity="center"
    android:padding="32dp">

    <!-- Logo -->
    <LinearLayout
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_button_primary"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📹"
            android:textSize="40sp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SmartCam Pro"
        android:textColor="#ffffff"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Professionelles Sicherheitssystem"
        android:textColor="#64748b"
        android:textSize="14sp"
        android:layout_marginBottom="36dp" />

    <EditText
        android:id="@+id/loginUsername"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="E-Mail oder Benutzername"
        android:textColor="#ffffff"
        android:textColorHint="#475569"
        android:background="@drawable/bg_input"
        android:inputType="text"
        android:textSize="15sp"
        android:layout_marginBottom="14dp" />

    <EditText
        android:id="@+id/loginPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Passwort"
        android:inputType="textPassword"
        android:textColor="#ffffff"
        android:textColorHint="#475569"
        android:background="@drawable/bg_input"
        android:textSize="15sp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Anmelden"
        android:textColor="#ffffff"
        android:background="@drawable/bg_button_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/loginError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#ef4444"
        android:textSize="13sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/skipLoginButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App testen (ohne Anmeldung)"
        android:textColor="#475569"
        android:textSize="13sp"
        android:padding="12dp" />
</LinearLayout>
