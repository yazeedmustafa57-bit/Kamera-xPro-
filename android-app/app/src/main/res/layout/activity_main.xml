<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="24dp"
    android:gravity="center">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_launcher"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SmartCam Pro"
        android:textColor="#ffffff"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Professionelles Sicherheitssystem"
        android:textColor="#94a3b8"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/serverUrlInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Server-URL (z.B. http://192.168.1.100:8000)"
        android:inputType="textUri"
        android:textColor="#ffffff"
        android:textColorHint="#64748b"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/cameraNameInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Kamera-Name"
        android:inputType="text"
        android:textColor="#ffffff"
        android:textColorHint="#64748b"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/usernameInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Benutzername"
        android:inputType="text"
        android:textColor="#ffffff"
        android:textColorHint="#64748b"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Passwort"
        android:inputType="textPassword"
        android:textColor="#ffffff"
        android:textColorHint="#64748b"
        android:background="@drawable/edit_text_bg"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Anmelden"
        android:textColor="#ffffff"
        android:backgroundTint="#3b82f6"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#ef4444"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center" />
</LinearLayout>
