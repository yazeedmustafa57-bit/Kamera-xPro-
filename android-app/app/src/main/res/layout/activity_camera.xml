<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#000000">
    <androidx.camera.view.PreviewView android:id="@+id/previewView" android:layout_width="match_parent" android:layout_height="match_parent" />

    <!-- Top status bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp" android:background="#CC000000" android:gravity="center_vertical">
        <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_status_online" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/statusText" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Verbinde..." android:textColor="#f59e0b" android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/batteryText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batterie: --%" android:textColor="#ffffff" android:textSize="11sp" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/viewersText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Zuschauer: 0" android:textColor="#94a3b8" android:textSize="11sp" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/qrButton" android:layout_width="wrap_content" android:layout_height="28dp" android:text="QR" android:textColor="#ffffff" android:background="@drawable/bg_button_purple" android:textSize="10sp" android:textAllCaps="false" android:paddingStart="8dp" android:paddingEnd="8dp" />
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:orientation="horizontal" android:padding="10dp" android:background="#CC000000" android:gravity="center">
        <Button android:id="@+id/switchCameraButton" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Drehen" android:textColor="#ffffff" android:background="@drawable/bg_button_dark" android:textSize="11sp" android:textAllCaps="false" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/flashButton" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Licht" android:textColor="#ffffff" android:background="@drawable/bg_button_dark" android:textSize="11sp" android:textAllCaps="false" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/alarmButton" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="ALARM" android:textColor="#ffffff" android:background="@drawable/bg_button_red" android:textSize="11sp" android:textAllCaps="false" android:textStyle="bold" android:layout_marginEnd="4dp" />
        <Button android:id="@+id/stopButton" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Stopp" android:textColor="#ffffff" android:background="@drawable/bg_button_red" android:textSize="11sp" android:textAllCaps="false" />
    </LinearLayout>
</FrameLayout>
